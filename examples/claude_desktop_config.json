{
  "mcpServers": {
    "infimium": {
      "command": "npx",
      "args": [
        "tsx",
        "src/index.ts"
      ],
      "cwd": "/absolute/path/to/infimium",
      "env": {
        "SEARCH_API_KEY": "",
        "SEARCH_PROVIDER": "brave",
        "LOCAL_DOCS_PATH": "",
        "CODEBASE_PATH": "",
        "SHELL_ALLOWLIST": "ls,git,npm,npx"
      }
    }
  }
}
